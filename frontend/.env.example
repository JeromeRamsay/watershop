# URL of the deployed (or local) NestJS API.
# Required — without this, all API calls will fail silently.
NEXT_PUBLIC_API_URL=http://localhost:4000

# Optional: when the employee app is served from a custom host,
# switch browser and server-action calls to the matching custom API host.
NEXT_PUBLIC_CUSTOM_APP_HOST=
NEXT_PUBLIC_CUSTOM_API_URL=

