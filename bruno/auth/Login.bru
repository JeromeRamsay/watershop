meta {
  name: Login
  type: http
  seq: 1
}

post {
  url: {{baseUrl}}/users/login
  body: json
  auth: none
}

body:json {
  {
    "username": "admin",
    "password": "secret123"
  }
}

script:post-response {
  if (res.status === 201 || res.status === 200) {
    bru.setVar("token", res.body.access_token);
  }
}

